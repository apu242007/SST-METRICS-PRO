# ─── Backend (server/index.js) ────────────────────────────────────────────────
# Ruta absoluta o relativa al archivo Excel de incidentes
INCIDENTS_XLSX_PATH=./data/basedatosincidentes.xlsx

# Destinatario del reporte diario por email
MAIL_TO=destinatario@empresa.com

# Origen permitido para CORS (URL del frontend en desarrollo o producción)
ALLOWED_ORIGIN=http://localhost:5173

# Configuración SMTP (nodemailer)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-usuario@gmail.com
# SMTP_PASS=tu-contraseña-de-aplicacion

# ─── Frontend (Vite — solo variables con prefijo VITE_ se exponen al cliente) ─
# ⚠️ SEGURIDAD: Mover la llamada a Gemini al backend antes de usar esta variable
# VITE_GEMINI_KEY=tu-api-key-aqui
